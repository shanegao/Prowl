# Prowl release environment variables
# Copy to .env and fill in values. .env is gitignored.

# Apple code signing (auto-detected if unset)
# APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAM_ID)
# APPLE_TEAM_ID=TEAM_ID
# APPLE_NOTARY_KEYCHAIN_PROFILE=supacode-notary

# Sparkle EdDSA private key (default: ~/.prowl-sparkle-private-key)
# SPARKLE_PRIVATE_KEY_FILE=~/.prowl-sparkle-private-key

# Netlify Build Hook for Prowl-Site rebuild after release
NETLIFY_BUILD_HOOK=
