#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${CI:-}" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ ! -e "ThirdParty/ghostty/.git" ]]; then
  exit 0
fi

if ! make -s ensure-ghostty; then
  echo "[post-merge] warning: ghostty sync failed; run 'make sync-ghostty'" >&2
fi
