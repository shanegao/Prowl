#!/usr/bin/env bash
set -euo pipefail

# post-checkout args: <old-ref> <new-ref> <is-branch-checkout>
if [[ "${3:-0}" != "1" ]]; then
  exit 0
fi

if [[ -n "${CI:-}" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ ! -e "ThirdParty/ghostty/.git" ]]; then
  exit 0
fi

if ! make -s ensure-ghostty; then
  echo "[post-checkout] warning: ghostty sync failed; run 'make sync-ghostty'" >&2
fi
